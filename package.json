{
  "name": "mokelay-editor",
  "private": true,
  "version": "0.0.5",
  "type": "module",
  "packageManager": "yarn@4.12.0",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build && node scripts/write-dist-package.mjs",
    "dist:package": "node scripts/write-dist-package.mjs",
    "publish:npm": "npm version patch && npm run build && npm pack --dry-run ./dist && npm publish ./dist",
    "preview": "vite preview",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:debug": "playwright test --debug",
    "e2e:install": "playwright install chromium",
    "deploy": "gh-pages -d dist --cname editor.mokelay.com",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@calumk/editorjs-columns": "^0.3.2",
    "@editorjs/editorjs": "^2.30.8",
    "@editorjs/table": "^2.4.5",
    "@headlessui/vue": "^1.7.23",
    "@tanstack/vue-query": "^5.66.9",
    "axios": "^1.8.1",
    "echarts": "^6.0.0",
    "element-ui": "npm:element-plus@^2.13.7",
    "reka-ui": "^2.3.1",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.13.5",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/tsconfig": "^0.7.0",
    "autoprefixer": "^10.4.20",
    "gh-pages": "^6.3.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.7.2",
    "vite": "^6.1.0",
    "vue-tsc": "^2.2.2"
  }
}
